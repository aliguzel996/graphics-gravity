{
  "name": "graphics-gravity",
  "version": "0.1.0",
  "description": "A 2D physics playground for type, shapes and graphics.",
  "main": "electron/main.cjs",
  "author": "Ali Guzel / YCSWU",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build:web": "vite build && node scripts/fix-web-build.cjs",
    "preview": "vite preview",
    "start": "npm run build:web && electron .",
    "dist:win": "npm run build:web && electron-builder --win nsis portable"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "37.10.3",
    "electron-builder": "^26.0.12",
    "vite": "^7.0.5"
  },
  "build": {
    "appId": "co.ycswu.graphicsgravity",
    "productName": "Graphics Gravity",
    "directories": { "output": "release/windows" },
    "files": ["dist/**/*", "electron/**/*", "assets/graphics-gravity.ico", "package.json"],
    "asar": true,
    "fileAssociations": [{ "ext": "graphicsGravity", "name": "Graphics Gravity Project", "description": "Graphics Gravity project file", "icon": "assets/graphics-gravity.ico", "role": "Editor" }],
    "win": { "target": ["nsis", "portable"], "icon": "assets/graphics-gravity.ico", "signAndEditExecutable": true },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/graphics-gravity.ico",
      "uninstallerIcon": "assets/graphics-gravity.ico",
      "artifactName": "graphics-gravity-setup-${version}-${arch}.${ext}"
    },
    "portable": { "artifactName": "graphics-gravity-portable-${version}-${arch}.${ext}" }
  }
}
